{
  "name": "@lutaml/lutaml-model",
  "version": "0.1.0",
  "private": false,
  "description": "JavaScript release of lutaml-model, published as @lutaml/lutaml-model on npm. Opal-compiled with optional shared runtime from @lutaml/opal-runtime.",
  "main": "./dist/lutaml-model-no-opal.js",
  "module": "./dist/lutaml-model-no-opal.js",
  "browser": "./dist/lutaml-model.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/lutaml-model.js",
      "import": "./dist/lutaml-model-no-opal.js",
      "require": "./dist/lutaml-model-no-opal.js",
      "default": "./dist/lutaml-model-no-opal.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "test": "node scripts/test.js"
  },
  "keywords": [
    "lutaml",
    "model",
    "opal",
    "ruby",
    "serialization"
  ],
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/lutaml/lutaml-model-js"
  },
  "homepage": "https://github.com/lutaml/lutaml-model-js#readme",
  "bugs": {
    "url": "https://github.com/lutaml/lutaml-model-js/issues"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@lutaml/opal-runtime": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@lutaml/opal-runtime": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}